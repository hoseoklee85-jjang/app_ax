// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id          String    @id // "KR", "US"
  name        String    // "LG Korea", "LG USA"
  currency    String    // "KRW", "USD"
  timezone    String    @default("UTC")
  products    Product[]
  orders      Order[]
}

model Product {
  id           Int                  @id @default(autoincrement())
  storeId      String               @default("KR")
  store        Store                @relation(fields: [storeId], references: [id])
  productCode  String?              @unique
  name         String
  price        Int                  // Base price
  description  String?
  stock        Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  orderItems   OrderItem[]
  translations ProductTranslation[]
}

model ProductTranslation {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  language    String   // "ko", "en", "es"
  name        String
  description String?

  @@unique([productId, language])
}

model Order {
  id              Int         @id @default(autoincrement())
  storeId         String      @default("KR")
  store           Store       @relation(fields: [storeId], references: [id])
  orderNumber     String      @unique
  customer        String
  customerEmail   String?
  customerPhone   String?
  shippingAddress String?
  paymentMethod   String      @default("CREDIT_CARD")
  total           Int
  status          String      @default("PENDING")
  notes           String?
  createdAt       DateTime    @default(now())
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]

  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([customer])
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  quantity    Int      @default(1)
  price       Int
  status      String   @default("PAID")
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("SUB_ADMIN") // SUPER_ADMIN or SUB_ADMIN
  createdAt DateTime @default(now())
}

model OrderStatusHistory {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  oldStatus String?
  newStatus String
  changedBy String   @default("SYSTEM")
  createdAt DateTime @default(now())
}
