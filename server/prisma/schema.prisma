generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------------
// ADMIN SPECIFIC TABLES
// ------------------------------------------------------------------------
model AdminUser {
  id        BigInt   @id @default(autoincrement())
  username  String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      String   @default("SUB_ADMIN") @db.VarChar(50)
  storeId   String?  @map("website") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("admin_users")
}

model OrderStatusHistory {
  id        Int      @id @default(autoincrement())
  orderId   BigInt   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  oldStatus String?
  newStatus String
  changedBy String   @default("SYSTEM")
  createdAt DateTime @default(now())
}

model ProductTranslation {
  id          Int      @id @default(autoincrement())
  productId   BigInt   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  language    String   // "ko", "en", "es"
  name        String
  description String?

  @@unique([productId, language])
}

// ------------------------------------------------------------------------
// SHARED TABLES (SPRING BOOT & ADMIN)
// ------------------------------------------------------------------------

model Store {
  id              String   @id @map("website_id") @db.VarChar(50)
  name            String   @map("country") @db.VarChar(255)
  currency        String   @map("subsidiary_code") @db.VarChar(50)
  timezone        String   @map("locale_code") @db.VarChar(50)
  
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy       String   @default("SYSTEM") @map("created_by") @db.VarChar(255)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  updatedBy       String   @default("SYSTEM") @map("updated_by") @db.VarChar(255)

  products        Product[]
  orders          Order[]
  members         Member[]

  @@map("website")
}

model Category {
  id              BigInt   @id @default(autoincrement()) @map("category_id")
  name            String   @db.VarChar(255)
  websiteId       String   @map("website_id") @db.VarChar(50)
  parentId        BigInt?  @map("parent_id")
  depth           Int
  slug            String   @unique @db.VarChar(255)
  sortOrder       Int      @default(0) @map("sort_order")

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy       String   @default("SYSTEM") @map("created_by") @db.VarChar(255)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  updatedBy       String   @default("SYSTEM") @map("updated_by") @db.VarChar(255)

  @@map("category")
}

model Product {
  id              BigInt   @id @default(autoincrement())
  name            String
  productCode     String   @unique @map("sku") @db.VarChar(255)
  categoryId      BigInt   @default(1) @map("category_id")
  storeId         String   @map("website_id") @db.VarChar(50)
  imageUrl        String?  @map("image_url")
  stock           Int      @default(0) @map("stock_quantity")
  isDiscounted    Boolean  @default(false) @map("is_discounted")
  price           Decimal  @db.Decimal(19, 2)
  originalPrice   Decimal? @map("original_price") @db.Decimal(19, 2)
  status          String   @default("ACTIVE") @db.VarChar(50)
  
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy       String   @default("SYSTEM") @map("created_by") @db.VarChar(255)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  updatedBy       String   @default("SYSTEM") @map("updated_by") @db.VarChar(255)

  // Polyfill for Admin UI
  description     String?  @ignore

  store           Store    @relation(fields: [storeId], references: [id])
  orderItems      OrderItem[]
  translations    ProductTranslation[]

  @@map("product")
}

model Order {
  id              BigInt   @id @default(autoincrement())
  storeId         String   @map("website_id") @db.VarChar(50)
  currency        String   @default("KRW") @db.VarChar(3)
  memberId        BigInt   @default(1) @map("member_id")
  orderNumber     String   @unique @map("order_number") @db.VarChar(255)
  status          String   @db.VarChar(255)
  total           Decimal  @map("total_amount") @db.Decimal(38, 2)

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy       String   @default("SYSTEM") @map("created_by") @db.VarChar(255)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  updatedBy       String   @default("SYSTEM") @map("updated_by") @db.VarChar(255)

  store           Store    @relation(fields: [storeId], references: [id])
  items           OrderItem[]
  addresses       OrderAddress[]
  statusHistory   OrderStatusHistory[]
  member          Member   @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Polyfills for Admin UI
  customer        String?  @ignore
  customerEmail   String?  @ignore
  customerPhone   String?  @ignore
  paymentMethod   String?  @ignore
  notes           String?  @ignore

  @@map("orders")
}

model OrderAddress {
  id              BigInt    @id @default(autoincrement())
  orderId         BigInt    @map("order_id")
  addressType     String    @map("address_type") @db.VarChar(20)
  recipientName   String    @map("recipient_name") @db.VarChar(100)
  email           String?   @db.VarChar(255)
  phoneNumber     String?   @map("phone_number") @db.VarChar(50)
  addressLine1    String    @map("address_line1") @db.VarChar(255)
  addressLine2    String?   @map("address_line2") @db.VarChar(255)
  addressLine3    String?   @map("address_line3") @db.VarChar(255)
  city            String    @db.VarChar(100)
  state           String?   @db.VarChar(100)
  zipCode         String    @map("zip_code") @db.VarChar(20)
  countryCode     String    @map("country_code") @db.VarChar(2)
  
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(6)

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

model OrderItem {
  id              BigInt   @id @default(autoincrement())
  orderId         BigInt   @map("order_id")
  productId       BigInt   @map("product_id")
  productName     String   @map("product_name") @db.VarChar(255)
  quantity        Int
  price           Decimal  @map("unit_price") @db.Decimal(38, 2)
  
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy       String   @default("SYSTEM") @map("created_by") @db.VarChar(255)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  updatedBy       String   @default("SYSTEM") @map("updated_by") @db.VarChar(255)

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: NoAction)

  status          String?  @ignore

  @@map("order_items")
}

model Member {
  id              BigInt    @id @default(autoincrement())
  websiteId       String?   @map("website_id") @db.VarChar(50)
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  firstName       String?   @map("first_name") @db.VarChar(100)
  lastName        String?   @map("last_name") @db.VarChar(100)
  phoneNumber     String?   @map("phone_number") @db.VarChar(255)
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  taxId           String?   @map("tax_id") @db.VarChar(255)
  customerGroup   String?   @map("customer_group") @db.VarChar(255)
  status          String    @db.VarChar(255)
  
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(6)

  store           Store?    @relation(fields: [websiteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  addresses       MemberAddress[]
  orders          Order[]

  @@map("members")
}

model MemberAddress {
  id              BigInt    @id @default(autoincrement())
  memberId        BigInt    @map("member_id")
  addressType     String    @map("address_type") @db.VarChar(20)
  isDefault       Boolean   @map("is_default")
  recipientName   String    @map("recipient_name") @db.VarChar(100)
  email           String?   @db.VarChar(255)
  phoneNumber     String?   @map("phone_number") @db.VarChar(50)
  addressLine1    String    @map("address_line1") @db.VarChar(255)
  addressLine2    String?   @map("address_line2") @db.VarChar(255)
  addressLine3    String?   @map("address_line3") @db.VarChar(255)
  city            String    @db.VarChar(100)
  state           String?   @db.VarChar(100)
  zipCode         String    @map("zip_code") @db.VarChar(20)
  countryCode     String    @map("country_code") @db.VarChar(2)
  
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(6)

  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("member_addresses")
}
