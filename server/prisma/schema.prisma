generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model category {
  category_id BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  website_id  String   @db.VarChar(50)
  parent_id   BigInt?
  depth       Int
  slug        String   @unique @db.VarChar(255)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)
  created_by  String   @default("SYSTEM") @db.VarChar(255)
  updated_by  String   @default("SYSTEM") @db.VarChar(255)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model members {
  id           BigInt    @id @default(autoincrement())
  created_at   DateTime  @db.Timestamp(6)
  email        String    @unique(map: "uk9d30a9u1qpg8eou0otgkwrp5d") @db.VarChar(255)
  name         String    @db.VarChar(255)
  phone_number String    @db.VarChar(255)
  status       String    @db.VarChar(255)
  updated_at   DateTime? @db.Timestamp(6)
}

model order_items {
  id           BigInt   @id @default(autoincrement())
  created_at   DateTime @db.Timestamp(6)
  created_by   String   @db.VarChar(255)
  updated_at   DateTime @db.Timestamp(6)
  updated_by   String   @db.VarChar(255)
  product_id   BigInt
  product_name String   @db.VarChar(255)
  quantity     Int
  unit_price   Decimal  @db.Decimal(38, 2)
  order_id     BigInt
  orders       orders   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fkbioxgbv59vetrxe0ejfubep1w")

  @@index([order_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id               BigInt        @id @default(autoincrement())
  created_at       DateTime      @db.Timestamp(6)
  created_by       String        @db.VarChar(255)
  updated_at       DateTime      @db.Timestamp(6)
  updated_by       String        @db.VarChar(255)
  country_code     String        @db.VarChar(2)
  currency         String        @db.VarChar(3)
  customer_id      BigInt
  order_number     String        @unique(map: "uknthkiu7pgmnqnu86i2jyoe2v7") @db.VarChar(255)
  shipping_address String        @db.VarChar(255)
  status           String        @db.VarChar(255)
  total_amount     Decimal       @db.Decimal(38, 2)
  order_items      order_items[]

  @@index([status])
  @@index([created_at])
  @@index([country_code])
}

model product {
  id             BigInt   @id @default(autoincrement())
  name           String
  sku            String   @unique @db.VarChar(255)
  category_id    BigInt
  website_id     String   @db.VarChar(50)
  image_url      String?
  stock_quantity Int      @default(0)
  is_discounted  Boolean  @default(false)
  price          Decimal  @db.Decimal(19, 2)
  original_price Decimal? @db.Decimal(19, 2)
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @default(now()) @db.Timestamp(6)
  created_by     String   @default("SYSTEM") @db.VarChar(255)
  updated_by     String   @default("SYSTEM") @db.VarChar(255)
  status         String   @default("ACTIVE") @db.VarChar(50)

  @@index([website_id])
  @@index([created_at])
}

model website {
  website_id      String   @id @db.VarChar(50)
  country         String   @db.VarChar(255)
  subsidiary_code String   @db.VarChar(50)
  locale_code     String   @db.VarChar(50)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @default(now()) @db.Timestamp(6)
  created_by      String   @default("SYSTEM") @db.VarChar(255)
  updated_by      String   @default("SYSTEM") @db.VarChar(255)
}

model admin_users {
  id         BigInt   @id @default(autoincrement())
  username   String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  role       String   @default("SUB_ADMIN") @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp(6)
}
